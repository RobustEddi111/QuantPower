   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# 创建一个包含缺失值的 DataFrame\n",
    "data = {\n",
    "    'A': [1, 2, np.nan, 4],\n",
    "    'B': [np.nan, 2, 3, 4]\n",
    "}\n",
    "X = pd.DataFrame(data)\n",
    "\n",
    "# 前状态\n",
    "print(\"前状态：\")\n",
    "print(X)\n",
    "\n",
    "# 数据处理：前向填充和删除缺失值\n",
    "X = X.fillna(method='ffill').dropna()\n",
    "\n",
    "# 后状态\n",
    "print(\"\\n后状态：\")\n",
    "print(X)\n"
   ]
